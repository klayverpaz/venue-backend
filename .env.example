# App
BACKEND_ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# DB — default é Postgres. Para SQL Server, comente a primeira linha e descomente a segunda.
BACKEND_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mydb
# BACKEND_DATABASE_URL=mssql+aioodbc://user:pass@localhost/mydb?driver=ODBC+Driver+18+for+SQL+Server
BACKEND_DB_POOL_SIZE=5

# Redis
BACKEND_REDIS_HOST=localhost
BACKEND_REDIS_PORT=6379
BACKEND_REDIS_USERNAME=
BACKEND_REDIS_PASSWORD=

# JWT
BACKEND_JWT_SECRET_KEY=dev-only-jwt-secret-DO-NOT-USE-IN-PROD
BACKEND_JWT_ALGORITHM=HS256
BACKEND_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
BACKEND_JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Argon2 (OWASP 2024 defaults)
BACKEND_ARGON2_TIME_COST=3
BACKEND_ARGON2_MEMORY_COST_KIB=12288
BACKEND_ARGON2_PARALLELISM=1
