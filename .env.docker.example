# Compose-only env file. Copy to .env.docker and tweak as needed.
# Loaded by docker-compose's `env_file:` directive into each service's environment;
# pydantic-settings reads the BACKEND_* vars directly from the container env.

BACKEND_ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# DB — pontas para o serviço `db` do compose
BACKEND_DATABASE_URL=postgresql+asyncpg://venue:venue@db:5432/venue
BACKEND_DB_POOL_SIZE=5

# Redis — ponta para o serviço `redis` do compose
BACKEND_REDIS_HOST=redis
BACKEND_REDIS_PORT=6379
BACKEND_REDIS_USERNAME=
BACKEND_REDIS_PASSWORD=

# JWT — troque o secret antes de levar pra prod
BACKEND_JWT_SECRET_KEY=dev-only-jwt-secret-DO-NOT-USE-IN-PROD
BACKEND_JWT_ALGORITHM=HS256
BACKEND_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
BACKEND_JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Argon2 (OWASP 2024 defaults; baixe se o container ficar lento)
BACKEND_ARGON2_TIME_COST=3
BACKEND_ARGON2_MEMORY_COST_KIB=12288
BACKEND_ARGON2_PARALLELISM=1

# Postgres service envs (lidos pelo serviço `db` do compose)
POSTGRES_USER=venue
POSTGRES_PASSWORD=venue
POSTGRES_DB=venue
